# Easypanel phone-app — set these in the service Environment tab
# Internal DB hostname (Docker network): db_solar_database
DATABASE_URL=postgresql://USER:PASSWORD@db_solar_database:5432/db_solar_v2
PORT=8080
NODE_ENV=production
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
# Optional: Django media for profile images
# MEDIA_ROOT=/path/to/media
