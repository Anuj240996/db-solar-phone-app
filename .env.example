# =============================================================================
# VPS production (phones / APK / IPA) — use on the server
# =============================================================================
DATABASE_URL=postgresql://heramb:Heramb2023@db_solar_database:5432/db_solar_v2
PORT=8080
NODE_ENV=production

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# MEDIA_ROOT=/path/on/vps/media
# MEDIA_BASE_URL=http://your-server-ip

# =============================================================================
# Local Windows development — uncomment for PC-only testing
# =============================================================================
# DATABASE_URL=postgresql://admin:root@localhost:5432/db_solar_v2
# PORT=3000
# NODE_ENV=development

# Email Configuration (for password reset — use a Gmail App Password, not login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# SMTP_FROM="DB Solar" <your-email@gmail.com>

# Firebase Admin SDK (for push notifications)
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
